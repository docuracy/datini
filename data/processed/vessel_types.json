{
  "_README": [
    "Italian → English mapping for the `Tipo Imbarcazioni` field of",
    "data/ViaggiJourney.csv (the Melis-archive late-medieval Mediterranean",
    "voyages data). Compiled from 45 distinct atomic tokens that appear",
    "in the source — composite strings like 'galea, galeotta' or",
    "'n.s., fusta' are split on comma at runtime and each token looked up.",
    "Where a vessel type has no precise English equivalent (most",
    "medieval Italian / Genoese / Venetian types do not), the original",
    "Italian word is kept with a parenthetical gloss; this preserves the",
    "specialist term while still being readable to an English audience.",
    "The 'n.s.' abbreviation stands for 'non specificato' — unspecified.",
    "Build script: scripts/build_journeys.py reads this file."
  ],
  "translations": {
    "barca":                "boat",
    "nave":                 "ship",
    "liuto":                "leuto (Ligurian/Sicilian trader)",
    "rampino":              "rampino (small coastal trader)",
    "legno":                "vessel",
    "galea":                "galley",
    "galeotta":             "galiot",
    "saettia":              "saettia (light galley)",
    "vacchetta":            "vacchetta (Adriatic small trader)",
    "navetta":              "small ship",
    "cocca":                "cog",
    "n.s.":                 "unspecified",
    "piatta":               "lighter (flat-bottomed)",
    "spinazza":             "pinnace",
    "bargia":               "barge",
    "galeazza":             "galleass",
    "brigantino":           "brigantine",
    "cocchetta":            "small cog",
    "destriera":            "destriera (horse-transport)",
    "destriero":            "destriero (horse-transport)",
    "2 coperte":            "two-decker",
    "3 coperte":            "three-decker",
    "fusta":                "fusta (small galley)",
    "barcozzo":             "barcozzo (small craft)",
    "barcozo":              "barcozzo (small craft)",
    "caracca":              "carrack",
    "panfilo":              "panfilo (small fast vessel)",
    "saetta":               "saetta (light galley)",
    "schifo":               "skiff",
    "scafo":                "scafo (hull/small vessel)",
